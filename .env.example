# This file documents ALL environment variables used across the project.
# Copy relevant sections into backend/.env and frontend/.env — never commit real .env files.

# ---- BACKEND ----
# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# CORS — set this to your Vite dev server's LAN-accessible URL
CORS_ORIGIN=http://192.168.1.42:5173

# Security
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=replace_this_with_a_long_random_string
AUTO_LOCK_MINUTES=5
MAX_PIN_ATTEMPTS=3
LOCKOUT_SECONDS=30

# Production single-server deploy
# SERVE_FRONTEND=true
# FRONTEND_DIST=../frontend/dist
# CORS_ORIGIN=http://localhost:5000

# ---- FRONTEND ----
# Development — LAN IP so your phone can reach the API
VITE_API_BASE_URL=http://192.168.1.42:5000

# Production — leave empty (uses relative /api); see frontend/.env.production

# ---- SMOKE TEST ----
# SMOKE_BASE_URL=http://localhost:5000
# SMOKE_TEST_PIN=123456